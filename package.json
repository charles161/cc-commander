{
  "name": "cc-commander",
  "version": "0.1.0",
  "description": "Turn any Claude Code session into a multi-agent orchestrator",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "commander": "dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": ["claude-code", "orchestrator", "multi-agent", "tmux"],
  "author": "charles161",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
